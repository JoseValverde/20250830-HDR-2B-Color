<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HDR 1B COLORS - Experiencia Visual Ultradinámico</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <div id="loading">
        <h1>HDR COLORS</h1>
        <div>Cargando experiencia visual ultradinámico...</div>
        <p>Por favor, espera un momento...</p>
    </div>
    
    <div id="info"></div>
    
    <div class="controls">
        <button id="btnSphere">Esfera</button>
        <button id="btnVortex">Vórtice</button>
        <button id="btnExplosion">Explosión</button>
        <button id="btnGrid">Cuadrícula</button>
        <button id="btnSettings">⚙️ Configuración</button>
    </div>
    
    <div id="settingsPanel">
        <h3 style="margin-top:0">Configuración</h3>
        <div class="settings-grid">
            <label for="particleCount">Cantidad:</label>
            <input type="range" id="particleCount" min="1000" max="100000" step="1000">
            <span id="valueParticleCount">25000</span>
            
            <label for="particleSize">Tamaño:</label>
            <input type="range" id="particleSize" min="0.01" max="0.5" step="0.01">
            <span id="valueParticleSize">0.05</span>
            
            <label for="particleSpeed">Velocidad:</label>
            <input type="range" id="particleSpeed" min="0.1" max="5" step="0.1">
            <span id="valueParticleSpeed">0.5</span>
            
            <label for="bloomStrength">Intensidad bloom:</label>
            <input type="range" id="bloomStrength" min="0" max="5" step="0.1">
            <span id="valueBloomStrength">1.5</span>
            
            <label for="bloomRadius">Radio bloom:</label>
            <input type="range" id="bloomRadius" min="0" max="2" step="0.05">
            <span id="valueBloomRadius">0.75</span>
            
            <label for="bloomThreshold">Umbral bloom:</label>
            <input type="range" id="bloomThreshold" min="0" max="1" step="0.05">
            <span id="valueBloomThreshold">0.2</span>
            
            <label for="colorSpeed">Velocidad color:</label>
            <input type="range" id="colorSpeed" min="0.1" max="5" step="0.1">
            <span id="valueColorSpeed">0.5</span>
            
            <label for="colorCycle">Ciclo de colores:</label>
            <input type="checkbox" id="colorCycle" checked>
        </div>
        <div class="button-container">
            <button id="btnApply">Aplicar</button>
            <button id="btnClose">Cerrar</button>
        </div>
    </div>
    
    <script type="module" src="js/main.js"></script>
</body>
</html>
